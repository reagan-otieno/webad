# Copy this file to .env and fill in your values
# Never commit .env to version control

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=adpay
DB_USER=adpay_user
DB_PASSWORD=your_strong_password_here

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string
JWT_EXPIRES_IN=7d

# Admin credentials (stored separately from DB for security)
ADMIN_EMAIL=admin@adpay.com
ADMIN_PASSWORD=Admin@Secure2025!
ADMIN_ACCESS_KEY=AP-MASTER-KEY

# Server
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://yourdomain.com

# Optional: SSL for PostgreSQL on hosted services (Railway, Render, etc.)
# DB_SSL=true
