{
  "name": "adpay-server",
  "version": "1.0.0",
  "description": "AdPay Node.js + PostgreSQL backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "setup-db": "psql $DATABASE_URL -f schema.sql",
    "setup-db-local": "psql -U adpay_user -d adpay -f schema.sql"
  },
  "engines": { "node": ">=18.0.0" },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
